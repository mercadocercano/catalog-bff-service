FROM golang:1.24-alpine

WORKDIR /app

# Instalar air para hot reload (versión compatible con Go 1.21)
RUN go install github.com/cosmtrek/air@v1.49.0

# Copiar go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copiar código fuente
COPY . .

# Exponer puerto
EXPOSE 8085

# Usar air para hot reload
CMD ["air", "-c", ".air.toml"]
